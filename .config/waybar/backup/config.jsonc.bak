{
  "position": "top",
  "margin-top": 10,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left": [
    "clock"
  ],

  "modules-center": [
    "hyprland/workspaces"
  ],

  "modules-right": [
    "network",
    "battery",
    "tray"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },

  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:%Y-%m-%d}"
  },

  "network": {
    "format-wifi": "ΎΘτ",
    "format-ethernet": "≤░ΛΩ",
    "format-disconnected": "≤░Ψς"
  },

  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": ["ΎΚΕ","ΎΚΔ","ΎΚΓ","ΎΚΒ","ΎΚΑ"]
  },

  "tray": {
    "icon-size": 16,
    "spacing": 6
  }
}