@import 'colors/rose-pine.css';

* {
  font-family: "CaskaydiaCove Nerd Font", sans-serif;
  font-size: 12px;
  border: none;

  border-radius: 0px;
  min-height: 0;
  padding: 0;
  margin: 0;
}

window#waybar {
  background: transparent;
}

tooltip {
  background: @surface;
  border: 1px solid @surface;
  border-radius: 12px;
}

tooltip label {
  color: @subtle;
  padding: 6px;
}

#workspaces {
  background-color: @surface;
  padding: 5px 3px;
  margin: 0 0 0 12px;
  border-radius: 36px;
}

#workspaces button {
  padding: 0 6px;
  margin: 0 3px;
  border-radius: 42px;
  color: @subtle;
  background-color: @base;
  min-width: 36px;
  transition: all 0.25s ease;
}

#workspaces button.active {
  background-color: @pine;
  color: @surface;
}

#workspaces button:hover {
  background-color: @iris;
  color: @base;
}

#workspaces button.urgent {
  background-color: @love;
  color: @base;
}

#battery,
#network,
#custom-notifications {
  background-color: @base;
  padding: 0 15px 0 15px;
  margin: 0 0 0 12px;
  border-radius: 48px;
  border: 1px solid @surface;
}

#clock {
  color: @pine
}

#custom-notifications {
  color: @subtle;
}

#network {
  color: @iris;
}

#battery {
  color: @foam;
}


